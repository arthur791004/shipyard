{
  "name": "shipyard",
  "private": true,
  "workspaces": ["backend", "frontend", "electron"],
  "scripts": {
    "dev": "npm-run-all -p dev:backend dev:frontend",
    "dev:backend": "npm --workspace backend run dev",
    "dev:frontend": "npm --workspace frontend run dev",
    "build": "npm --workspace backend run build && npm --workspace frontend run build",
    "electron:build": "npm --workspace electron-app run build",
    "electron:dev": "npm --workspace electron-app run build && npm --workspace electron-app run start",
    "postinstall": "chmod +x node_modules/node-pty/prebuilds/darwin-*/spawn-helper 2>/dev/null || true"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
