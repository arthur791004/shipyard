#!/usr/bin/env bash
# shipyard:sandbox — CLI bridge for sandboxed Claude to invoke host-mediated
# git operations via the backend HTTP API. The sandbox's outbound proxy has a
# per-sandbox allow rule for the backend port, added by ensureRepoSandbox.
#
# Env vars (injected by sandbox.ts when the claude session starts):
#   SHIPYARD_BRANCH_ID    — the branch this sandbox belongs to
#   SHIPYARD_BACKEND_URL  — e.g. http://host.docker.internal:9090
set -euo pipefail

usage() {
  cat >&2 <<EOF
usage: shipyard:sandbox <command> [args]

commands:
  commit -m <msg> [--amend]   stage all changes and commit on the host
  commit --amend              amend the previous commit without changing its message
  push                        push the current branch and create/update its PR
EOF
  exit 2
}

cmd="${1:-}"
shift || true
[ -z "$cmd" ] && usage

BACKEND="${SHIPYARD_BACKEND_URL:-http://host.docker.internal:9090}"
BRANCH="${SHIPYARD_BRANCH_ID:-}"
if [ -z "$BRANCH" ]; then
  echo "error: SHIPYARD_BRANCH_ID not set in sandbox env" >&2
  exit 1
fi

case "$cmd" in
  commit)
    message=""
    amend=0
    has_m=0
    while [ $# -gt 0 ]; do
      case "$1" in
        -m)
          [ $# -lt 2 ] && { echo "error: -m requires an argument" >&2; exit 2; }
          message="$2"
          has_m=1
          shift 2
          ;;
        --amend)
          amend=1
          shift
          ;;
        *)
          echo "error: unknown arg: $1" >&2
          usage
          ;;
      esac
    done
    if [ $amend -eq 0 ] && [ $has_m -eq 0 ]; then
      echo "error: -m <message> required (or use --amend)" >&2
      exit 2
    fi
    url="$BACKEND/api/branches/$BRANCH/commit"
    [ $amend -eq 1 ] && url="$url?amend=1"
    # printf '%s' preserves embedded newlines and % verbatim; --data-binary
    # @- streams the message body from stdin so we don't have to escape.
    printf '%s' "$message" | curl -sS --fail-with-body -X POST \
      -H "Content-Type: text/plain" --data-binary @- "$url"
    ;;
  push)
    url="$BACKEND/api/branches/$BRANCH/push"
    # Test/CI escape hatch — tells backend to skip the real git/gh calls.
    if [ "${SHIPYARD_PUSH_DRYRUN:-}" = "1" ]; then
      url="$url?dryRun=1"
    fi
    # No body is sent, so don't set Content-Type (Fastify's JSON parser
    # rejects an empty body when content-type is application/json).
    exec curl -sS --fail-with-body -X POST "$url"
    ;;
  *)
    usage
    ;;
esac
