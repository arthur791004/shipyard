#!/usr/bin/env bash
# shipyard:sandbox — file-based RPC bridge from sandboxed Claude to the host
# backend. The sandbox's egress proxy blocks the backend's HTTP port, so we
# drop request files into a bind-mounted directory and poll for a response
# file. See backend/src/rpc.ts for the host side of this protocol.
#
# Env vars (injected by sandbox.ts when the claude session starts):
#   SHIPYARD_BRANCH_ID  — the branch this sandbox belongs to
#   SHIPYARD_RPC_DIR    — path to the shared RPC dir (bind-mounted from host)
set -euo pipefail

usage() {
  cat >&2 <<EOF
usage: shipyard:sandbox <command> [args]

commands:
  commit -m <msg> [--amend]   stage all changes and commit on the host
  commit --amend              amend the previous commit without changing its message
  push                        push the current branch and create/update its PR
EOF
  exit 2
}

cmd="${1:-}"
shift || true
[ -z "$cmd" ] && usage

BRANCH="${SHIPYARD_BRANCH_ID:-}"
RPC_DIR="${SHIPYARD_RPC_DIR:-}"
if [ -z "$BRANCH" ]; then
  echo "error: SHIPYARD_BRANCH_ID not set in sandbox env" >&2
  exit 1
fi
if [ -z "$RPC_DIR" ]; then
  echo "error: SHIPYARD_RPC_DIR not set in sandbox env" >&2
  exit 1
fi

mkdir -p "$RPC_DIR"

# Unique request id — avoid collisions across parallel invocations.
if command -v uuidgen >/dev/null 2>&1; then
  id=$(uuidgen | tr -d '-' | head -c 16)
else
  id="$(date +%s%N)-$$"
fi

message=""
amend=0
has_m=0
qs=""

case "$cmd" in
  commit)
    while [ $# -gt 0 ]; do
      case "$1" in
        -m)
          [ $# -lt 2 ] && { echo "error: -m requires an argument" >&2; exit 2; }
          message="$2"
          has_m=1
          shift 2
          ;;
        --amend)
          amend=1
          shift
          ;;
        *)
          echo "error: unknown arg: $1" >&2
          usage
          ;;
      esac
    done
    if [ $amend -eq 0 ] && [ $has_m -eq 0 ]; then
      echo "error: -m <message> required (or use --amend)" >&2
      exit 2
    fi
    [ $amend -eq 1 ] && qs="amend=1"
    # Write body first (so it's in place when the backend picks up the .req).
    printf '%s' "$message" > "$RPC_DIR/$id.body.tmp"
    mv "$RPC_DIR/$id.body.tmp" "$RPC_DIR/$id.body"
    ;;
  push)
    if [ $# -gt 0 ]; then
      echo "error: unknown arg: $1" >&2
      usage
    fi
    # Test/CI escape hatch — tells backend to skip the real git/gh calls.
    [ "${SHIPYARD_PUSH_DRYRUN:-}" = "1" ] && qs="dryRun=1"
    ;;
  *)
    usage
    ;;
esac

# Drop the request file last. Atomic mv means the backend never sees a
# partial line.
printf '%s %s %s' "$cmd" "$BRANCH" "$qs" > "$RPC_DIR/$id.req.tmp"
mv "$RPC_DIR/$id.req.tmp" "$RPC_DIR/$id.req"

# Poll for <id>.<status>. 60-second budget at 100ms tick.
cleanup() {
  rm -f "$RPC_DIR/$id.req" "$RPC_DIR/$id.body" 2>/dev/null || true
}

iters=600
while [ $iters -gt 0 ]; do
  for f in "$RPC_DIR/$id."*; do
    [ -f "$f" ] || continue
    base="${f##*/}"
    suffix="${base#"$id."}"
    case "$suffix" in
      req|body|*.tmp) continue ;;
    esac
    # Response files have a 3-digit HTTP status as the extension.
    case "$suffix" in
      [0-9][0-9][0-9]) ;;
      *) continue ;;
    esac
    body=$(cat "$f")
    rm -f "$f"
    cleanup
    printf '%s' "$body"
    if [ "$suffix" -ge 200 ] && [ "$suffix" -lt 300 ]; then
      exit 0
    else
      exit 22
    fi
  done
  sleep 0.1
  iters=$((iters - 1))
done

echo "error: timeout waiting for backend (60s)" >&2
cleanup
exit 1
